# DeployContext configuration — copy to .env and fill in. NEVER commit .env.

# Slack bot token (xoxb-…). Slack app → Install App → Bot User OAuth Token,
# after creating the app from slack-manifest.json and installing to your sandbox.
SLACK_BOT_TOKEN=

# Slack app-level token (xapp-…) for Socket Mode. Slack app → Basic Information
# → App-Level Tokens → Generate (scope: connections:write).
SLACK_APP_TOKEN=

# Anthropic API key (sk-ant-…). https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GitHub personal access token for the BOT account (classic PAT, `repo` scope).
# Used to read the manifest/config and to push fix branches + open PRs.
# Local dev shortcut: GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=

# The product repo the registry points at, owner/name.
GITHUB_REPO=VikramIyer125/fake-product

# Unleash server. Defaults match docker-compose.yml in this repo
# (docker compose up -d; then npm run setup:unleash).
UNLEASH_URL=http://localhost:4242

# Unleash CLIENT API token (server-side SDK, production environment).
# Pre-provisioned by docker-compose.yml via INIT_CLIENT_API_TOKENS.
# (Self-managed Unleash: Admin → API access → create a client token.)
UNLEASH_API_TOKEN=default:production.deploycontext-insecure-client-token

# Unleash ADMIN API token (flag metadata lookups + scripts/setup-unleash.ts).
# Pre-provisioned by docker-compose.yml via INIT_ADMIN_API_TOKENS.
UNLEASH_ADMIN_TOKEN=*:*.deploycontext-insecure-admin-token

# Channel ID of #deploys (passive deploy-watch listener is scoped to this one
# channel). Printed by `npm run seed:slack`, or copy from the channel's
# "About" tab in Slack.
DEPLOY_CHANNEL_ID=

# Path of the registry manifest inside GITHUB_REPO.
MANIFEST_PATH=deployments.yaml

# Seeded log fixtures consumed by the log connector.
LOG_FIXTURES_PATH=fixtures/logs.json

# SQLite working memory (proposals + investigations). Disposable.
SQLITE_PATH=data/deploycontext.db

# Fixer sandbox tier: "docker" (primary; container whose network is
# disconnected after init) or "tempdir" (fallback; host temp dir, no container).
WORKSPACE_TIER=docker

# OPTIONAL: image for the fixer container (default node:22, which includes
# git). Build a slimmer one with: docker build -t deploycontext-fixer -f docker/fixer.Dockerfile .
#DOCKER_FIXER_IMAGE=deploycontext-fixer
